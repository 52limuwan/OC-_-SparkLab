# 数据库配置
DATABASE_URL="file:./spark_lab.db"
# 生产环境切换为：postgresql://user:password@localhost:5432/spark_lab

# JWT 配置
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# 服务器配置
PORT=3001
NODE_ENV="development"

# Docker 配置
DOCKER_HOST="unix:///var/run/docker.sock"
# 远程 Docker: tcp://192.168.1.100:2375

# Go Docker Bridge（本地 Docker 操作改由 Go SDK 执行）
DOCKER_GO_URL="http://127.0.0.1:8085"

# 容器自动回收配置
AUTO_STOP_TIMEOUT=1800000  # 30分钟（毫秒）
CLEANUP_INTERVAL=300000     # 5分钟检查一次

# 资源限制
DEFAULT_CPU_LIMIT=1.0
DEFAULT_MEMORY_LIMIT=512    # MB
MAX_CONTAINERS_PER_USER=3

# 前端地址（CORS）
FRONTEND_URL="http://localhost:3000"
