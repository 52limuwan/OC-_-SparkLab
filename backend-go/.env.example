PORT=3001
GIN_MODE=debug

# 使用 Prisma 现有 SQLite
DATABASE_URL="file:../backend/prisma/spark_lab.db"

JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"
FRONTEND_URL="http://localhost:3000"

# Agent 离线判定（支持 Go duration，如 10s/1m；也支持纯数字秒）
AGENT_OFFLINE_TIMEOUT="10s"
AGENT_OFFLINE_CHECK_INTERVAL="5s"
